<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ph_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/ph_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/ph_toolbar_bg"
        app:contentInsetStart="0dp"
        app:contentInsetStartWithNavigation="0dp"
        app:navigationIcon="@drawable/ph_ic_arrow_back"
        app:navigationContentDescription="@string/ph_back_desc">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/ph_title"
            android:textColor="@color/ph_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ph_share"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/ph_share_desc"
            android:src="@drawable/ph_ic_share" />
    </androidx.appcompat.widget.Toolbar>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/ph_filter_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <include
                android:id="@+id/ph_filter_quote"
                layout="@layout/ph_filter_chip" />

            <include
                android:id="@+id/ph_filter_metric"
                layout="@layout/ph_filter_chip" />

            <include
                android:id="@+id/ph_filter_range"
                layout="@layout/ph_filter_chip" />

            <include
                android:id="@+id/ph_filter_scope"
                layout="@layout/ph_filter_chip" />
        </LinearLayout>
    </HorizontalScrollView>

    <com.example.heatmap.HeatmapTreemapView
        android:id="@+id/ph_treemap"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="12dp" />
</LinearLayout>
